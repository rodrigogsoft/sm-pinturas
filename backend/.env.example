# =============================================================
# SM Pinturas & Construções — Backend
# Copie para .env e preencha os valores
# =============================================================

NODE_ENV=development
PORT=3006
API_PREFIX=api
API_VERSION=v1

DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=sm_pinturas_db
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

MFA_APP_NAME=SM Pinturas ERP
MFA_ISSUER=SM Pinturas

# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=
ENCRYPTION_IV=

CORS_ORIGIN=http://localhost:3010
CORS_CREDENTIALS=true

THROTTLE_TTL=60
THROTTLE_LIMIT=100

JOBS_TIMEZONE=America/Sao_Paulo
JOBS_DEADLINE_CHECK_CRON=0 6 * * *
JOBS_DASHBOARD_CACHE_CRON=0 */1 * * *

FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_URL=

LOG_LEVEL=debug
LOG_PRETTY=true

GEO_TOLERANCE_METERS=100
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg
