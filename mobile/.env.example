# API Configuration
API_URL=http://localhost:3000/api
API_VERSION=v1

# Environment
ENV=development

# Application
APP_NAME=SM Pinturas
APP_VERSION=1.0.0

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Feature Flags
ENABLE_DEBUG=true
ENABLE_OFFLINE_MODE=true

# Sync Configuration
SYNC_INTERVAL_MINUTES=5
MAX_OFFLINE_DAYS=7
